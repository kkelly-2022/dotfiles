        "tools": [
          "read",
          "grep",
          "find",
          "ls",
          "bash"
        ]
      },
      "delegate": {
        "model": "ollama/gemma4:latest",
        "fallbackModels": [
          "openai-codex/gpt-5.4-mini"
        ],
        "tools": [
          "read",
          "grep",
          "find",
          "ls"
        ]
      },
      "context-builder": {
        "model": "ollama/gemma4:latest",
        "fallbackModels": [
          "openai-codex/gpt-5.4"
        ],
        "tools": [
          "read",
          "grep",
          "find",
          "ls",
          "bash"
        ]
      },
      "researcher": {
        "model": "openai-codex/gpt-5.4-mini"
      },
      "reviewer": {
        "model": "openai-codex/gpt-5.4",
        "thinking": "high"
      },
      "worker": {
        "model": "openai-codex/gpt-5.4"
      },
      "planner": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "high"
      },
      "oracle": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "high"
      }
    }
  }
